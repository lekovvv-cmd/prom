# Local-only values. Do not place production secrets in this file.
PLATFORM_ENVIRONMENT=development
PLATFORM_FRONTEND_ORIGIN=http://localhost:5173
PLATFORM_DEBUG=false

ACCESS_DATABASE_URL=postgresql+psycopg://prom_access:prom_access@access-db:5432/prom_access
ACCESS_DB_PASSWORD=prom_access
ACCESS_JWT_PRIVATE_KEY=
ACCESS_JWT_KEY_ID=local-ephemeral
ACCESS_TRUSTED_HEADERS_ENABLED=false
ACCESS_OIDC_ENABLED=false

PROJECTS_DATABASE_URL=postgresql+psycopg://project_showcase:project_showcase@projects-db:5432/project_showcase
PROJECTS_DB_PASSWORD=project_showcase
PROJECTS_JWT_SECRET=change-me-in-production-at-least-32-bytes
PROJECTS_UPLOADS_DIR=/app/storage/projects

SERVICE_DESK_DATABASE_URL=postgresql+psycopg://service_desk:service_desk@service-desk-db:5432/service_desk
SERVICE_DESK_DB_PASSWORD=service_desk
SERVICE_DESK_JWT_SECRET=change-me-in-production-at-least-32-bytes
SERVICE_DESK_STORAGE_DIR=/app/storage/service-desk

SSO_PROVIDER=mock
SSO_ISSUER_URL=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_REDIRECT_URI=
SSO_SCOPES=openid profile email
SSO_JWKS_CACHE_TTL=300
SSO_ALLOWED_AUDIENCES=
SSO_POST_LOGOUT_REDIRECT_URI=

OTEL_ENABLED=false
OTEL_SERVICE_NAME=prom-platform
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_TRACES_SAMPLER=parentbased_traceidratio

STORAGE_BACKEND=filesystem
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=

VITE_PROJECTS_API_BASE_URL=/api
VITE_SERVICE_DESK_API_BASE_URL=/service-desk-api
VITE_ACCESS_API_BASE_URL=/api/access/v1

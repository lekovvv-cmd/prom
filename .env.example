PROJECTS_MAX_ATTACHMENT_SIZE_BYTES=10485760
PROJECTS_MAX_ATTACHMENTS_PER_OWNER=10
PROJECTS_ATTACHMENT_ORPHAN_GRACE_SECONDS=3600
PROJECTS_WORKER_METRICS_PORT=9100
PROJECTS_DB_POOL_SIZE=5
PROJECTS_DB_MAX_OVERFLOW=5
PROJECTS_DB_POOL_TIMEOUT_SECONDS=30
PROJECTS_DB_POOL_RECYCLE_SECONDS=1800
PROJECTS_DB_STATEMENT_TIMEOUT_MS=30000
PROJECTS_DB_APPLICATION_NAME=prom-projects-api


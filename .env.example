# Local-only values. Do not place production secrets in this file.
PLATFORM_ENVIRONMENT=development
PLATFORM_FRONTEND_ORIGIN=http://localhost:5173
PLATFORM_DEBUG=false
PLATFORM_INTERNAL_TOKEN_ISSUER=prom-access
PLATFORM_INTERNAL_TOKEN_AUDIENCE=prom-platform

ACCESS_DATABASE_URL=postgresql+psycopg://prom_access:prom_access@access-db:5432/prom_access
ACCESS_DB_PASSWORD=prom_access
ACCESS_JWT_PRIVATE_KEY=
ACCESS_JWT_KEY_ID=local-ephemeral
ACCESS_TOKEN_ISSUER=prom-access
ACCESS_TOKEN_AUDIENCES=projects,service-desk
ACCESS_TRUSTED_HEADERS_ENABLED=false
ACCESS_TRUSTED_PROXY_NETWORKS=
ACCESS_OIDC_ENABLED=false
ACCESS_DB_POOL_SIZE=5
ACCESS_DB_MAX_OVERFLOW=5
ACCESS_DB_POOL_TIMEOUT_SECONDS=30
ACCESS_DB_POOL_RECYCLE_SECONDS=1800
ACCESS_DB_STATEMENT_TIMEOUT_MS=30000
ACCESS_DB_APPLICATION_NAME=prom-access-api

PROJECTS_DATABASE_URL=postgresql+psycopg://project_showcase:project_showcase@projects-db:5432/project_showcase
PROJECTS_DB_PASSWORD=project_showcase
PROJECTS_JWT_SECRET=change-me-in-production-at-least-32-bytes
PROJECTS_ACCESS_JWKS_URL=http://access-service:8002/.well-known/jwks.json

SERVICE_DESK_APP_NAME=PROM Service Desk
SERVICE_DESK_SERVICE_CODE=service-desk
SERVICE_DESK_ENV=development
SERVICE_DESK_DEBUG=false
SERVICE_DESK_DATABASE_URL=postgresql+psycopg://service_desk:service_desk@localhost:5433/service_desk
SERVICE_DESK_JWT_SECRET=change-me-in-production-at-least-32-bytes
SERVICE_DESK_JWT_ALGORITHM=HS256
SERVICE_DESK_ACCESS_JWKS_URL=http://access-service:8002/.well-known/jwks.json
SERVICE_DESK_ACCESS_TOKEN_ISSUER=prom-access
SERVICE_DESK_ACCESS_TOKEN_AUDIENCE=service-desk
SERVICE_DESK_ACCESS_JWKS_CACHE_TTL_SECONDS=300
SERVICE_DESK_ACCESS_JWKS_STALE_IF_ERROR_SECONDS=3600
SERVICE_DESK_ACCESS_CLOCK_SKEW_SECONDS=30
SERVICE_DESK_ALLOW_LEGACY_TOKENS=false
SERVICE_DESK_FRONTEND_ORIGIN=http://localhost:5173
SERVICE_DESK_STORAGE_DIR=storage/service-desk
SERVICE_DESK_STORAGE_BACKEND=filesystem
SERVICE_DESK_S3_ENDPOINT=
SERVICE_DESK_S3_BUCKET=
SERVICE_DESK_S3_ACCESS_KEY=
SERVICE_DESK_S3_SECRET_KEY=
SERVICE_DESK_S3_REGION=
SERVICE_DESK_STORAGE_SIGNED_URL_TTL_SECONDS=60
SERVICE_DESK_ANTIVIRUS_BACKEND=noop
SERVICE_DESK_CLAMAV_HOST=clamav
SERVICE_DESK_CLAMAV_PORT=3310
SERVICE_DESK_CLAMAV_TIMEOUT_SECONDS=10
SERVICE_DESK_MAX_ATTACHMENT_SIZE_BYTES=10485760
SERVICE_DESK_MAX_ATTACHMENTS_PER_OWNER=10
SERVICE_DESK_ATTACHMENT_ORPHAN_GRACE_SECONDS=3600
SERVICE_DESK_ATTACHMENT_REJECTED_RETENTION_DAYS=7
SERVICE_DESK_WORKER_METRICS_PORT=9100
SERVICE_DESK_DB_POOL_SIZE=5
SERVICE_DESK_DB_MAX_OVERFLOW=5
SERVICE_DESK_DB_POOL_TIMEOUT_SECONDS=30
SERVICE_DESK_DB_POOL_RECYCLE_SECONDS=1800
SERVICE_DESK_DB_STATEMENT_TIMEOUT_MS=30000
SERVICE_DESK_DB_APPLICATION_NAME=prom-service-desk-api
SERVICE_DESK_SLA_WORKER_POLL_INTERVAL_SECONDS=60
SERVICE_DESK_NOTIFICATION_LIST_DEFAULT_LIMIT=30
SERVICE_DESK_NOTIFICATION_LIST_MAX_LIMIT=100
SERVICE_DESK_NOTIFICATION_OUTBOX_BATCH_SIZE=50
SERVICE_DESK_NOTIFICATION_OUTBOX_MAX_ATTEMPTS=8
SERVICE_DESK_NOTIFICATION_OUTBOX_RETRY_BASE_SECONDS=5
SERVICE_DESK_NOTIFICATION_OUTBOX_RETRY_MAX_SECONDS=3600
SERVICE_DESK_NOTIFICATION_OUTBOX_CLEANUP_BATCH_SIZE=500
SERVICE_DESK_NOTIFICATION_OUTBOX_PROCESSED_RETENTION_DAYS=30
SERVICE_DESK_NOTIFICATION_OUTBOX_DEAD_RETENTION_DAYS=90

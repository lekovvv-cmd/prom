PROJECTS_APP_NAME=Project Showcase SHPIU
PROJECTS_ENV=development
PROJECTS_DEBUG=false
PROJECTS_DATABASE_URL=postgresql+psycopg://project_showcase:project_showcase@localhost:5432/project_showcase
PROJECTS_JWT_SECRET=change-me-in-production-at-least-32-bytes
PROJECTS_JWT_ALGORITHM=HS256
PROJECTS_ACCESS_JWKS_URL=http://access-service:8002/.well-known/jwks.json
PROJECTS_ACCESS_TOKEN_ISSUER=prom-access
PROJECTS_ACCESS_TOKEN_AUDIENCE=projects
PROJECTS_ACCESS_JWKS_CACHE_TTL_SECONDS=300
PROJECTS_ACCESS_JWKS_STALE_IF_ERROR_SECONDS=3600
PROJECTS_ACCESS_CLOCK_SKEW_SECONDS=30
PROJECTS_ALLOW_LEGACY_TOKENS=false
PROJECTS_ACCESS_TOKEN_EXPIRE_MINUTES=1440
PROJECTS_FRONTEND_ORIGIN=http://localhost:5173
PROJECTS_UPLOADS_DIR=storage/uploads
PROJECTS_STORAGE_BACKEND=local
PROJECTS_S3_BUCKET=
PROJECTS_S3_ENDPOINT_URL=
PROJECTS_S3_REGION_NAME=
PROJECTS_S3_ACCESS_KEY_ID=
PROJECTS_S3_SECRET_ACCESS_KEY=
PROJECTS_ANTIVIRUS_BACKEND=noop
PROJECTS_CLAMAV_HOST=clamav
PROJECTS_CLAMAV_PORT=3310
PROJECTS_MAX_ATTACHMENT_SIZE_BYTES=10485760
PROJECTS_MAX_ATTACHMENTS_PER_OWNER=10
PROJECTS_ATTACHMENT_ORPHAN_GRACE_SECONDS=3600
PROJECTS_WORKER_METRICS_PORT=9100
PROJECTS_DB_POOL_SIZE=5
PROJECTS_DB_MAX_OVERFLOW=5
PROJECTS_DB_POOL_TIMEOUT_SECONDS=30
PROJECTS_DB_POOL_RECYCLE_SECONDS=1800
PROJECTS_DB_STATEMENT_TIMEOUT_MS=30000
PROJECTS_DB_APPLICATION_NAME=prom-projects-api
